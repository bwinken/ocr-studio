# ══════════════════════════════════════════════════
# Image Doc Translator - Environment Variables
# Copy to .env and modify as needed
# ══════════════════════════════════════════════════

# ── PDF Rendering ──
PDF_RENDER_SCALE=2.0

# ── Text Block Detection (bbox) ──
VLM_DET_ENDPOINT=http://localhost:8000/v1/chat/completions
VLM_DET_MODEL=glm-ocr
VLM_DET_API_KEY=
VLM_DET_MAX_TOKENS=4096
VLM_DET_TEMPERATURE=0.1
# VLM_DET_PROMPT=自定义检测prompt

# ── OCR Text Recognition ──
VLM_OCR_ENDPOINT=http://localhost:8000/v1/chat/completions
VLM_OCR_MODEL=glm-ocr
VLM_OCR_API_KEY=
VLM_OCR_MAX_TOKENS=4096
VLM_OCR_TEMPERATURE=0.1
# VLM_OCR_PROMPT=自定义OCR prompt

# ── Combined Mode (detection + OCR in one call) ──
# Set to true if your model can return both bbox and text
VLM_COMBINED_MODE=true
# VLM_COMBINED_PROMPT=自定义合并prompt

# ── Translation ──
VLM_TRANSLATE_ENDPOINT=http://localhost:8000/v1/chat/completions
VLM_TRANSLATE_MODEL=gptoss-20b
VLM_TRANSLATE_API_KEY=
VLM_TRANSLATE_MAX_TOKENS=4096
VLM_TRANSLATE_TEMPERATURE=0.3
# VLM_TRANSLATE_PROMPT=自定义翻译prompt

# ── Cleanup ──
# Auto-delete uploaded documents after N minutes (0 = never)
STORAGE_TTL_MINUTES=30
